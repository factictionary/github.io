# ============================================================================
# KEEP THESE FILES (Exceptions)
# ============================================================================
!.gitkeep
!README.md
!CNAME
!.github/
!.github/workflows/
!.github/ISSUE_TEMPLATE/
!.github/PULL_REQUEST_TEMPLATE/

# ============================================================================
# Project-specific exclusions for Factictionary
# ============================================================================

# Exclude all markdown files except README
*.md
!README.md

# Exclude Python scripts and tools (backend only)
scripts/
#*.py
*.pyc
__pycache__/
*.ps1

# Exclude documentation and guides (internal use only)
*_GUIDE.md
*_SUMMARY.md
*_IMPLEMENTATION*.md
*_UPDATES*.md
*_STRATEGY*.md
ADSENSE_*.md
AFFILIATE_*.md
AMAZON_*.md
BROWSER_*.md
ENHANCED_*.md
AUTOMATIC_*.md
CONTENT_*.md
WORKSPACE_*.md
COMPLETION_*.md
STOREFRONT_*.md
NAVIGATION_*.md
PRODUCT_*.md
FINAL_*.md
APP_IDEAS*.md
YOUTUBE_*.md
CHANGES_*.txt
ARTICLES_*.txt

# Exclude configuration files that shouldn't be committed
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Exclude temporary documentation
ADSENSE_COMPLIANCE_GUIDE.md
WEBSITE_UPDATES_SUMMARY.md
QUICK_START_ADSENSE.md
IMPLEMENTATION_COMPLETE.md
NEW_ARTICLES_ADDED.md
TRAFFIC_GROWTH_STRATEGY.md
CHANGES_SUMMARY.txt
ARTICLES_SUMMARY.txt

# Exclude backup and temporary files
*.bak
*.backup
*.tmp
*.temp
*~

# Exclude OS files
.DS_Store
Thumbs.db
.directory

# Exclude IDE files
.vscode/
.idea/
*.swp
*.swo

# Exclude build and cache
node_modules/
.cache/
.jekyll-cache/
_site/

# Exclude logs
*.log
logs/

# Exclude environment files
.env
.env.local

# Exclude output directories from scripts
output/
temp/
tmp/

# ============================================================================
# END OF .gitignore
# ============================================================================
